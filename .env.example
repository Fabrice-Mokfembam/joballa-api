# Prefer sslmode=verify-full (matches current Node/pg behavior & avoids the sslmode=require deprecation warning).
# See: https://www.postgresql.org/docs/current/libpq-ssl.html — or use Neon/host docs for their recommended query string.
# App runtime — use Neon *pooled* URL (-pooler in hostname) on production.
DATABASE_URL="postgresql://username:password@host-pooler:5432/database?sslmode=verify-full"
# Recommended on Render for `prisma migrate deploy` — Neon *direct* URL (no -pooler).
# Optional if DATABASE_URL is a standard Neon pooler URL (direct host is derived automatically).
# Strongly recommended for local dev too (avoids "Connection terminated unexpectedly").
# See helperdocs/RENDER_NEON_DEPLOY.md
DIRECT_DB_URL="postgresql://username:password@host:5432/database?sslmode=verify-full"
PORT=8000
NODE_ENV="development"

# Canonical API URL for smoke scripts and tooling (same host as deployed API)
API_URL=https://joballa-api-production.up.railway.app

# Optional — error monitoring (imported first in src/main.ts via src/instrument.ts)
# SENTRY_DSN="https://your-key@o000000.ingest.us.sentry.io/0000000"
# SENTRY_SEND_PII=true

# Auth — TTL values are seconds (numbers)
JWT_SECRET="change-me-minimum-32-characters-long-secret"
JWT_ACCESS_EXPIRES_SEC="900"
JWT_REFRESH_EXPIRES_SEC="604800"
OTP_EXPIRES_MINUTES="10"

# Google Sign-In (worker / employer only — ID token flow)
# Web client ID — joballa-web + primary API audience
GOOGLE_CLIENT_ID="775095047347-t0kapvp1ltmitbpgla75oeh1n7pe916j.apps.googleusercontent.com"
# Mobile client IDs (Android + iOS) — comma-separated
GOOGLE_CLIENT_IDS="775095047347-d7ped466si81km6q1c5aeel2se1mrhpm.apps.googleusercontent.com,775095047347-1buj6ld6dan566uh1mvjclpc42g0edoo.apps.googleusercontent.com"

# --- Refresh cookies (plain explanation: helperdocs/AUTH_COOKIES_SIMPLE.md) ---
COOKIE_DOMAIN=
COOKIE_PATH=/
COOKIE_SAME_SITE=none
# COOKIE_SECURE=

# Local / CI auth scripts only (never in production): fixed 6-digit OTP for register/forgot/resend flows
JOBALLA_DEV_FIXED_OTP=

# Messaging (OTP delivery — optional locally; OTP is logged when missing)
# Resend — use onboarding@resend.dev until joballa.com is verified (https://resend.com/domains)
RESEND_API_KEY=""
RESEND_FROM_NAME="Joballa"
RESEND_FROM_EMAIL="onboarding@resend.dev"
# Optional; only after you own reply domain in Resend
RESEND_REPLY_TO=""

AFRICAS_TALKING_API_KEY=""
# Sandbox must use username "sandbox" and BASE_URL api.sandbox.africastalking.com
AFRICAS_TALKING_USERNAME=""
# Not used — OTP SMS omits sender `from`; AT assigns default branded sender per account rules.
AFRICAS_TALKING_SENDER_ID=""
# Live: https://api.africastalking.com — Sandbox key must use https://api.sandbox.africastalking.com (username often "sandbox").
AFRICAS_TALKING_BASE_URL="https://api.africastalking.com"

# Admin portal smokes use https://joballa-api.onrender.com by default.
# For local API tests only: JOBALLA_ADMIN_USE_LOCAL=1

# Employer portal smokes (same production default)
# JOBALLA_EMPLOYER_USE_LOCAL=1
# JOBALLA_EMPLOYER_IDENTIFIER=
# JOBALLA_EMPLOYER_PASSWORD=
# JOBALLA_EMPLOYER_BOOTSTRAP=1

# Worker portal smokes (default https://joballa-api.onrender.com)
# JOBALLA_WORKER_USE_LOCAL=1
# JOBALLA_WORKER_IDENTIFIER=
# JOBALLA_WORKER_PASSWORD=
# JOBALLA_WORKER_BOOTSTRAP=1

# Admin portal smoke tests (existing super admin on deployed API)
JOBALLA_ADMIN_IDENTIFIER="superadmin@joballa.cm"
JOBALLA_ADMIN_PASSWORD=""

# Set to 1 only to seed a throwaway super admin via Prisma (same DATABASE_URL as API)
# JOBALLA_ADMIN_BOOTSTRAP=0

# Allow any frontend origin (localhost:3000, :5173, etc.). Use on Render for demos.
CORS_ALLOW_ALL=true
# Or list origins (ignored when CORS_ALLOW_ALL=true): CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Empty CORS_ORIGINS also allows all origins (same as CORS_ALLOW_ALL).
CORS_ORIGINS=
TRUST_PROXY=1

# Optional: extra Nest framework logs (debug / verbose); HTTP access logs are always on via [HTTP] logger.
NEST_DEBUG_LOG=

////////////////////////////
// Cloudinary Configuration
///////////////////////////
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
# Push notifications (Expo Push API — server only; never expose to clients)
EXPO_ACCESS_TOKEN=""
