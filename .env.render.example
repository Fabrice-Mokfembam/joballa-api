# Copy these into Render → Environment (production API).
# Do NOT commit real secrets to git — paste your real values in the Render dashboard.

NODE_ENV=production

# --- CORS: allow localhost, Vite, etc. during demos ---
CORS_ALLOW_ALL=true
CORS_ORIGINS=

# --- Cookies (localhost frontend → joballa-api.onrender.com) ---
# Leave COOKIE_DOMAIN empty. Never set "localhost" on Render.
COOKIE_DOMAIN=
COOKIE_PATH=/
COOKIE_SAME_SITE=none
# COOKIE_SECURE=   (leave empty — production forces Secure automatically)

# --- Auth (use strong secrets on Render) ---
JWT_SECRET=replace-with-long-random-secret-min-32-chars
JWT_ACCESS_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_SEC=604800
OTP_EXPIRES_MINUTES=10

# --- Database (from Neon console) ---
DATABASE_URL=postgresql://...@ep-xxx-pooler....neon.tech/neondb?sslmode=verify-full
DIRECT_DB_URL=postgresql://...@ep-xxx....neon.tech/neondb?sslmode=verify-full

TRUST_PROXY=1

# Plus your existing: RESEND_*, AFRICAS_TALKING_*, CLOUDINARY_*, etc.
